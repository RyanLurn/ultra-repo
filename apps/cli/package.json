{
  "name": "@ultra-repo/cli",
  "type": "module",
  "bin": {
    "ultra": "dist/index.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit",
    "lint": "eslint --cache",
    "lint:fix": "eslint --cache --fix",
    "check": "pnpm run check-types && pnpm run lint"
  },
  "dependencies": {
    "@ultra-repo/core": "workspace:*",
    "commander": "^14.0.3",
    "yaml": "^2.8.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "@ultra-repo/eslint-config": "workspace:*",
    "@ultra-repo/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "tsdown": "catalog:build",
    "typescript": "catalog:"
  }
}
